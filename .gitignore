
# Claudify — personal & runtime files
CLAUDE.local.md
.claude/logs/
.claude/agent-memory/
.claude/backups/
.claude/hooks/__counter
__NEEDS_ONBOARD

# ESP-IDF build artefacts
/build/
/sdkconfig
/sdkconfig.old
/managed_components/
/dependencies.lock
/.cache/
/.clangd

# Android app build + node deps
/android-app/android/*
!/android-app/android/app/
/android-app/android/app/*
!/android-app/android/app/src/
/android-app/android/app/src/*
!/android-app/android/app/src/main/
/android-app/android/app/src/main/*
!/android-app/android/app/src/main/java/
# Keep our custom Kotlin native module + MainApplication edits in git.
# Rest of android/ (gradle, wrappers, build outputs) stays untracked —
# regenerated by `expo prebuild` (without --clean, see memory note).
/android-app/node_modules/
/android-app/build/
/android-app/.expo/

# Installer binaries (large, regenerable) — but keep the .iss scripts
/installer/*
!/installer/*.iss

# Editor
/.vscode/

# Scratch / personal notes
Scratchpad.md
Daily Notes/
Task Board.md
SETUP.md

# Claudify runtime (not part of product code)
/.claude/
/CLAUDE.md

# MCP config
/.mcp.json
